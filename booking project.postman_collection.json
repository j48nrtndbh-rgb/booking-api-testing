        {
          "name": "get all booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "  const response = pm.response.json();",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Get one booking\", () =>{",
                  "    pm.expect(response).to.be.an(\"array\");",
                  "    pm.expect(response.length).to.be.above(0);",
                  "    });",
                  "    bookingId = response[0]",
                  "    pm.test('should be an oject', () => {",
                  "         pm.expect(bookingId).to.be.an(\"object\");",
                  "    pm.expect(bookingId).to.haveOwnProperty(\"bookingid\");",
                  "    });",
                  "    ",
                  "pm.test(\"bookingid should be a number\", () => {",
                  "    pm.expect(bookingId.bookingid).to.be.a(\"number\")",
                  "});",
                  "    pm.test(\"Response size is within reasonable limits (below 5KB)\", function () {",
                  "    pm.expect(pm.response.responseSize).to.be.below(500000);",
                  "});",
                  "",
                  "  ",
                  "",
                  ""
                ],
