        {
          "name": "create booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"create was Successfull\", () => {",
                  "const response = pm.response.json();",
                  "pm.expect(response).to.be.an('object');",
                  "pm.expect(response.booking.firstname).to.eql(\"John\")",
                  "pm.expect(response.booking.totalprice).to.be.a('number')",
                  "",
                  "pm.test('verify checkin and chekout dates are correct', () => {",
                  "    pm.expect(response.booking.bookingdates.checkin).to.eql('2018-01-01');",
                  "    pm.expect(response.booking.bookingdates.checkout).to.eql(\"2019-01-01\");",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"bookingId\", response.bookingid);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
